# For local preview that mirrors GitHub Pages' classic build.
# Run:  bundle install  &&  bundle exec jekyll serve --safe
# Then open http://localhost:4000  (remote_theme is fetched over the network on build).
source "https://rubygems.org"

# The same gem GitHub Pages runs (pins Jekyll + the allowed plugin set).
gem "github-pages", group: :jekyll_plugins

# remote_theme isn't bundled in the github-pages gem locally; add it explicitly.
gem "jekyll-remote-theme"
